PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/helpdesk"

# Required. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

BETTER_AUTH_URL="http://localhost:3000"

# Comma-separated list of origins allowed to make cross-origin requests.
# Must include the frontend URL. Required — server will not start without it.
TRUSTED_ORIGINS="http://localhost:5173"

ANTHROPIC_API_KEY=""

# Used only by the seed script (bun run db:seed).
# SEED_ADMIN_PASSWORD must be at least 16 characters — the seed script enforces this.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="<set-a-strong-password-before-seeding>"
